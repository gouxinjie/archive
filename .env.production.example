# ECS 生产环境变量模板
NODE_ENV=production

# Nuxt 服务监听地址和端口
# ECS 上通常监听 0.0.0.0，再由 Nginx / Caddy / 宝塔反向代理到公网域名
HOST=0.0.0.0
PORT=3000

# 生产访问地址，必须改成你的 ECS 域名或公网 HTTPS 地址
# 示例：https://archive.example.com
NUXT_PUBLIC_ORIGIN=https://your-ecs-domain.example.com

# 单人系统 userId，保持默认 owner 即可
NUXT_OWNER_USER_ID=owner

# 会话 Cookie 签名密钥，生产环境必须替换为至少 32 位随机字符串
NUXT_SESSION_SECRET=please-change-to-a-random-32-character-secret

# 文件预览短链接签名密钥，生产环境必须替换为至少 32 位随机字符串
NUXT_FILE_PREVIEW_SECRET=please-change-file-preview-secret-32

# ECS 本机持久化目录：数据库
NUXT_DATABASE_PATH=/var/www/archive-data/data/archive.db

# ECS 本机持久化目录：上传的图片、文档、简历、证件和学习资料文件
NUXT_UPLOADS_DIR=/var/www/archive-data/uploads

# 个人账号初始/重置密码，生产必须替换为强密码
NUXT_PERSONAL_ACCOUNT_PASSWORD=please-change-personal-password

# 演示账号初始/重置密码；公网生产环境不建议使用默认 123456
NUXT_DEMO_ACCOUNT_PASSWORD=please-change-demo-password
